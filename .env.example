# Copy this file to .env and fill in your API keys
# Multiple keys can be comma-separated for round-robin load balancing
# Example: DEEPSEEK_API_KEY=sk-key1,sk-key2,sk-key3

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
QWEN_API_KEY=sk-your-qwen-key-here
KIMI_API_KEY=sk-your-kimi-key-here

# Optional: Anthropic (no longer used as judge, but kept for reference)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
